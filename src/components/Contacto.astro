            alt="communication"
          />
        </div>

        <h3 class="text-2xl text-center py-2">Gestión de Garantias</h3>
        <p class="text-lg pb-2 text-center">
          Respaldo total en cada venta. Nuestro servicio de Gestión de Garantías
          asegura que cualquier inconveniente con los repuestos adquiridos sea
          atendido de manera eficiente y profesional.
        </p>
      </div>

      <a
        target="_blank"
        href="https://api.whatsapp.com/send?phone=573132202239"
        class="text-center w-full border-black py-4"
        style="border-top: 1px solid rgba(179, 179, 179, 0.5);"
